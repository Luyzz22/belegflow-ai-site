# .env.example

# API Configuration
API_URL=https://api.example.com
API_KEY=your_api_key_here

# Security Settings
ENABLE_SSL=true
JWT_SECRET=your_jwt_secret_here

# Compliance Flags
GDPR_COMPLIANT=true
NIS2_COMPLIANT=true
EU_AI_ACT_COMPLIANT=true

# Feature Flags
FEATURE_X_ENABLED=true
FEATURE_Y_ENABLED=false
